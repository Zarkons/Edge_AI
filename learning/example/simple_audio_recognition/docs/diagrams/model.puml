@startuml
' Layout Configuration
skinparam BackgroundColor transparent
skinparam RoundCorner 6
skinparam ArrowColor #5F6368
skinparam ArrowThickness 1.5

' Design Elements Scheme
skinparam rectangle {
    BackgroundColor #E8F0FE
    BorderColor #1A73E8
    FontColor #174EA6
    FontSize 12
    StereotypeFontColor #174EA6
}

skinparam queue {
    BackgroundColor #E6F4EA
    BorderColor #137333
    FontColor #137333
}

skinparam component {
    BackgroundColor #FCE8E6
    BorderColor #C5221F
    FontColor #A51D24
}

' Architectural Layers Map
queue "Dataset Ingestion\n(tf.data.Dataset)" as Dataset

rectangle "Input Layer\nshape: input_shape" as Input
rectangle "Resizing Layer\ndownsample to 32x32" as Resize
rectangle "Normalization Layer\n(Adapted via Dataset)" as Norm
rectangle "Conv2D Layer 1\n32 Filters / 3x3 / ReLU" as Conv1
rectangle "Conv2D Layer 2\n64 Filters / 3x3 / ReLU" as Conv2
rectangle "MaxPooling2D Layer\nSpatial Reduction" as Pool

component "Dropout Layer (25%)\nRate: 0.25" as Drop1

rectangle "Flatten Layer\nTensor Dimensional Flattening" as Flatten
rectangle "Dense Layer\n128 Units / ReLU" as Dense1

component "Dropout Layer (50%)\nRate: 0.5" as Drop2

rectangle "Dense Output Layer\nnum_labels Units / Softmax" as Output

' Execution Routing Pipeline
Dataset .down.> Norm : Adaptation Feed

Input -down-> Resize
Resize -down-> Norm
Norm -down-> Conv1
Conv1 -down-> Conv2
Conv2 -down-> Pool
Pool -down-> Drop1
Drop1 -down-> Flatten
Flatten -down-> Dense1
Dense1 -down-> Drop2
Drop2 -down-> Output
@enduml
